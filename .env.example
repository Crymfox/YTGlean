# YTGlean Environment Variables
# Copy this file to .env and fill in your values.

# OpenAI-compatible API key (works with OpenAI, Ollama, LM Studio, etc.)
# YTGLEAN_API_KEY=sk-...

# Override the API endpoint (default: https://api.openai.com/v1)
# YTGLEAN_ENDPOINT=http://localhost:11434/v1

# Override config file path
# YTGLEAN_CONFIG=/path/to/config.yaml
